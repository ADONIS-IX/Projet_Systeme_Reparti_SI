pipeline {
    agent any

    environment {
        // ── Dépôt Git ─────────────────────────────────────────────────────
        GITHUB_REPO       = 'https://github.com/ADONIS-IX/Projet_Systeme_Reparti_SI.git'

        // ── Docker Hub ────────────────────────────────────────────────────
        DOCKER_HUB_USER   = 'adonisdocker'
        DOCKER_HUB_CREDS  = credentials('dockerhub-credentials')
        BACKEND_IMAGE     = "${DOCKER_HUB_USER}/backend"
        FRONTEND_IMAGE    = "${DOCKER_HUB_USER}/frontend"

        // ── URL de l'API (inject au build du frontend) ────────────────────
        // URL relative : Nginx proxifie /api/ → backend (fonctionne en Docker Compose et Kubernetes)
        REACT_APP_API_URL = "/api"
    }

    stages {

        // ── Étape 1 : Récupération du code ────────────────────────────────
        stage('Préparation') {
            steps {
                echo '📥 Récupération du code source...'
                checkout scm
            }
        }

        // ── Étape 2 : Linting & Tests ─────────────────────────────────────
        stage('Linting & Tests') {
            parallel {

                stage('Backend — Lint') {
                    steps {
                        dir('backend') {
                            sh '''
                                python3 -m venv .venv
                                . .venv/bin/activate
                                pip install --quiet -r requirements.txt flake8
                                flake8 --max-line-length=120 \
                                       --exclude=.venv,migrations \
                                       .
                            '''
                        }
                    }
                }

                stage('Frontend — Install') {
                    steps {
                        dir('frontend') {
                            sh 'npm ci --silent'
                        }
                    }
                }
            }
        }

        // ── Étape 3 : Build & Push des images Docker ──────────────────────
        stage('Build & Push Images') {
            steps {
                script {
                    // Connexion Docker Hub
                    sh "echo ${DOCKER_HUB_CREDS_PSW} | docker login -u ${DOCKER_HUB_CREDS_USR} --password-stdin"

                    // Backend
                    sh """
                        docker build -t ${BACKEND_IMAGE}:${BUILD_NUMBER} \
                                     -t ${BACKEND_IMAGE}:latest \
                                     ./backend
                        docker push ${BACKEND_IMAGE}:${BUILD_NUMBER}
                        docker push ${BACKEND_IMAGE}:latest
                    """

                    // Frontend (injection de l'URL de l'API au moment du build)
                    sh """
                        docker build \
                            --build-arg REACT_APP_API_URL=${REACT_APP_API_URL} \
                            -t ${FRONTEND_IMAGE}:${BUILD_NUMBER} \
                            -t ${FRONTEND_IMAGE}:latest \
                            ./frontend
                        docker push ${FRONTEND_IMAGE}:${BUILD_NUMBER}
                        docker push ${FRONTEND_IMAGE}:latest
                    """
                }
            }
        }

        // ── Étape 4 : Déploiement Kubernetes ─────────────────────────────
        stage('Déploiement Kubernetes') {
            steps {
                script {
                    // Appliquer tous les manifests (Secrets inclus → pas d'interaction)
                    sh 'kubectl apply -f k8s/'

                    // Mettre à jour les images avec le tag du build courant
                    sh """
                        kubectl set image deployment/backend  backend=${BACKEND_IMAGE}:${BUILD_NUMBER}
                        kubectl set image deployment/frontend frontend=${FRONTEND_IMAGE}:${BUILD_NUMBER}
                    """

                    // Attendre la fin du rollout
                    sh 'kubectl rollout status deployment/backend  --timeout=120s'
                    sh 'kubectl rollout status deployment/frontend --timeout=120s'
                }
            }
        }

        // ── Étape 5 : Migrations Django ───────────────────────────────────
        stage('Migrations Django') {
            steps {
                script {
                    def pod = sh(
                        script: "kubectl get pods -l app=backend -o jsonpath='{.items[0].metadata.name}'",
                        returnStdout: true
                    ).trim()
                    sh "kubectl exec ${pod} -- python manage.py migrate --noinput"
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline terminé avec succès !'
        }
        failure {
            echo '❌ Échec du pipeline. Consultez les logs ci-dessus.'
        }
        always {
            sh 'docker logout || true'
            cleanWs()
        }
    }
}
